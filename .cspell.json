{
  "version": "0.2",
  "language": "en",
  "words": [
    "husky",
    "commitlint",
    "cspell",
    "secretlint",
    "eslint",
    "prettier"
  ],
  "ignorePaths": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    ".git/**",
    "*.log",
    "package-lock.json",
    "yarn.lock",
    "pnpm-lock.yaml"
  ],
  "ignoreRegExpList": [
    "/\\b[A-Z]{2,}\\b/g",
    "/0x[0-9a-fA-F]+/g",
    "/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/gi"
  ],
  "allowCompoundWords": true,
  "caseSensitive": false
}
